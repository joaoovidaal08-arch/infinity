// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CreativeMode {
  minimal_twitter
  viral_bold
  hybrid
}

enum FormatType {
  feed_square
  story_vertical
}

enum GenerationStatus {
  queued
  planning
  copy_generated
  layout_generated
  rendering
  validating
  completed
  failed
}

enum StepStatus {
  pending
  running
  completed
  failed
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workspaces Workspace[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  brands    Brand[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id               String            @id @default(cuid())
  workspaceId      String
  name             String
  toneOfVoice      String?
  paletteJson      Json?
  fontConfigJson   Json?
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects         Project[]
  creativeProfiles CreativeProfile[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model CreativeProfile {
  id                String       @id @default(cuid())
  brandId           String
  name              String
  mode              CreativeMode
  visualDensity     Int          @default(30)
  contrastLevel     Int          @default(80)
  typographyWeight  Int          @default(70)
  spacingLevel      Int          @default(70)
  graphicsIntensity Int          @default(20)
  tokensJson        Json?
  brand             Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  projects          Project[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Project {
  id                String           @id @default(cuid())
  brandId           String
  name              String
  description       String?
  creativeProfileId String?
  brand             Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creativeProfile   CreativeProfile? @relation(fields: [creativeProfileId], references: [id], onDelete: SetNull)
  briefs            ContentBrief[]
  posts             Post[]
  exports           Export[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model ContentBrief {
  id             String       @id @default(cuid())
  projectId      String
  topic          String
  objective      String?
  audience       String?
  cta            String?
  voice          String?
  baseLanguage   String       @default("pt-BR")
  preferredMode  CreativeMode
  targetFormats  FormatType[]
  slideCount     Int          @default(7)
  storyFrameCount Int         @default(3)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts          Post[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Post {
  id          String          @id @default(cuid())
  projectId   String
  briefId     String?
  title       String
  status      GenerationStatus @default(queued)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brief       ContentBrief?   @relation(fields: [briefId], references: [id], onDelete: SetNull)
  slides      Slide[]
  storyFrames StoryFrame[]
  jobs        GenerationJob[]
  assets      Asset[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Slide {
  id           String      @id @default(cuid())
  postId       String
  orderIndex   Int
  headline     String
  supporting   String?
  cta          String?
  creativeMode CreativeMode
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  assets       Asset[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([postId, orderIndex])
}

model StoryFrame {
  id           String      @id @default(cuid())
  postId       String
  orderIndex   Int
  headline     String
  supporting   String?
  cta          String?
  creativeMode CreativeMode
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  assets       Asset[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([postId, orderIndex])
}

model Template {
  id           String       @id @default(cuid())
  name         String
  formatType   FormatType
  creativeMode CreativeMode
  configJson   Json
  isActive     Boolean      @default(true)
  assets       Asset[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, formatType, creativeMode])
}

model GenerationJob {
  id            String           @id @default(cuid())
  postId         String
  creativeMode   CreativeMode
  status         GenerationStatus @default(queued)
  inputSnapshot  Json
  currentStep    String?
  attemptCount   Int             @default(0)
  errorCode      String?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  post           Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  steps          GenerationStep[]
  assets         Asset[]
  exports        Export[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model GenerationStep {
  id          String      @id @default(cuid())
  jobId        String
  stepName     String
  status       StepStatus @default(pending)
  inputHash    String
  outputRef    String?
  durationMs   Int?
  attempt      Int        @default(1)
  errorMessage String?
  job          GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([jobId, stepName, attempt])
}

model Asset {
  id           String      @id @default(cuid())
  jobId        String
  postId       String
  slideId      String?
  storyFrameId String?
  templateId   String?
  formatType   FormatType
  variantIndex Int         @default(1)
  width        Int
  height       Int
  storageUrl   String
  metadataJson Json?
  job          GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  slide        Slide?        @relation(fields: [slideId], references: [id], onDelete: SetNull)
  storyFrame   StoryFrame?   @relation(fields: [storyFrameId], references: [id], onDelete: SetNull)
  template     Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Export {
  id          String     @id @default(cuid())
  projectId   String
  jobId       String
  formatType  FormatType
  zipUrl      String
  totalAssets Int
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job         GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
}
